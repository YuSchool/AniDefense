  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Wie spiele ich AniDefense? W\xE4hle im Dungeon-Screen ein Level und eine
    Schwierigkeit aus. Platziere T\xFCrme auf den markierten Baufeldern auf der Karte.
    Starte die Wave mit dem Button unten rechts und verhindere dass Gegner deine
    Basis erreichen. \xDCberlebe alle 5 Waves um zu gewinnen. Ressourcen: Gold verdienst
    du durch besiegte Gegner und verwendest es zum Bauen von T\xFCrmen. Seelen werden
    zum Upgraden von T\xFCrmen ben\xF6tigt. Aura ist eine spezielle Ressource f\xFCr
    starke Aktionen. Du hast 3 Leben, verlierst du alle ist das Spiel vorbei."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d5d29d0e793c33642b062aa6de158925, type: 2}
  m_sharedMaterial: {fileID: 8947047975994586038, guid: d5d29d0e793c33642b062aa6de158925, type: 2}
