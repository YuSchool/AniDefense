  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Steuerung und Tipps: Um einen Turm zu bauen klicke eine Karte in der Bauliste
    an und dann ein freies Baufeld auf der Karte. Um einen Turm zu upgraden klicke
    einen bereits platzierten Turm an und best\xE4tige das Upgrade im Panel. Das
    Spiel kannst du \xFCber den Einstellungs-Button oben rechts im HUD pausieren.
    Die Schwierigkeiten Leicht, Normal und Schwer m\xFCssen der Reihe nach freigeschaltet
    werden indem du die vorherige Schwierigkeit abschlie\xDFt. Tipp: Upgrade deine
    T\xFCrme zwischen den Waves um st\xE4rker zu werden."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d5d29d0e793c33642b062aa6de158925, type: 2}
  m_sharedMaterial: {fileID: 8947047975994586038, guid: d5d29d0e793c33642b062aa6de158925, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
